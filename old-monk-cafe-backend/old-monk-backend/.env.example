# ===== SERVER =====
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
API_BASE_URL=http://localhost:5000

# ===== DATABASE =====
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/oldmonkcafe?retryWrites=true&w=majority

# ===== JWT =====
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d
JWT_COOKIE_EXPIRES_DAYS=7

# ===== ADMIN SEED (used only by scripts/seedAdmin.js) =====
ADMIN_NAME=Old Monk Admin
ADMIN_EMAIL=admin@oldmonkcafe.com
ADMIN_PASSWORD=ChangeMe@12345
ADMIN_PHONE=9296935757

# ===== CLOUDINARY =====
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===== EMAIL (NODEMAILER - SMTP) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="OLD MONK CAFE <no-reply@oldmonkcafe.com>"
ADMIN_NOTIFICATION_EMAIL=admin@oldmonkcafe.com

# ===== RAZORPAY =====
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ===== WHATSAPP (Twilio WhatsApp Business API) =====
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
CAFE_WHATSAPP_NUMBER=whatsapp:+919296935757

# ===== RATE LIMITING =====
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=100
